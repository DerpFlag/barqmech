**/node_modules/
**/dist/
**/dist-ssr/
**/.vite/

# Env files (examples are whitelisted below)
**/.env
**/.env.local
**/.env.*.local

# Logs & OS
*.log
.DS_Store
Thumbs.db

# IDE / local tooling
.idea/
.vscode/*
!.vscode/extensions.json
.cursor/

# Vercel
.vercel/

# TypeScript build info
**/.tmp/
**/*.tsbuildinfo

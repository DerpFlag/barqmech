{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && cd store && npm install",
  "buildCommand": "cd store && npm run build",
  "outputDirectory": "store/dist",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}

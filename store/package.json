{
  "name": "store",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "db:apply-orders": "node scripts/apply-orders-migration.mjs",
    "db:apply-sql": "node scripts/apply-sql-file.mjs",
    "import:catalog": "cross-env DRY_RUN=0 node --env-file=.env.import.local scripts/import-finalized-catalog.mjs",
    "import:catalog:dry": "cross-env DRY_RUN=1 node scripts/import-finalized-catalog.mjs",
    "dev:api": "node --env-file=.env.local scripts/dev-api-server.mjs",
    "build": "tsc -b && vite build",
    "analyze": "tsc -b && cross-env ANALYZE=1 vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "csv-parse": "^6.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "pg": "^8.14.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}

# Copy to .env.local for local API (node --env-file=.env.local scripts/dev-api-server.mjs).
# On Vercel, set these in Project → Settings → Environment Variables.
#
# --- Storefront catalog (Vite browser) — required for products to load on the shop ---
# Supabase → Settings → API: use Project URL and the anon (JWT) public key.
# If the dashboard only shows a "publishable" key, use whatever Supabase labels as the client-safe key.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_client_key
# Local shortcut: SUPABASE_URL + SUPABASE_ANON_KEY (no VITE_ prefix) also work — see vite.config.ts
#
# --- One-time catalog import (local or CI only; NEVER commit real values) ---
# Copy the lines you need into store/.env.import.local (gitignored via **/.env.*.local).
# Media/Keys.txt is plain notes, not dotenv format — paste URL + service role as KEY=value here.
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret
# Optional: PRICES_CSV=...  FINALIZED_ROOT=...  DRY_RUN=1
# Run: cd store && npm run import:catalog:dry   then   npm run import:catalog

# --- Checkout / orders (api/place-order.mjs) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_publishable_or_anon_key
# Service role (secret): required for /api/admin-* and for DXF signed download links in order emails (api/place-order.mjs).
# Never expose in the browser. Dashboard → Settings → API.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key

# Admin control centre (/admin). On production (Vercel), ADMIN_PASSWORD must be set or login is disabled.
ADMIN_PASSWORD=barq123mech
# Optional: signing key for admin session cookie (defaults to service role key if unset — set a long random string in production).
# ADMIN_SESSION_SECRET=
RESEND_API_KEY=re_xxxxxxxx
ORDER_FROM_EMAIL=onboarding@resend.dev
ORDER_NOTIFY_EMAIL=you@example.com

# Optional CORS if storefront and API differ by origin
# ALLOWED_ORIGIN=https://your-domain.vercel.app

# Optional: canonical site URL for order emails if checkout origin is missing (e.g. server-side tests)
# PUBLIC_SITE_URL=https://your-domain.vercel.app

# --- Contact form & email validation (api/contact.ts, api/validate-email.ts) ---
# Display name + angle brackets + address (Resend accepts this format).
RESEND_FROM_EMAIL=BarqMech <onboarding@resend.dev>
CONTACT_TO_EMAIL=you@example.com

# --- ZeroBounce (optional): same key for /api/validate-email, /api/contact, /api/place-order ---
# If unset, email format is still checked but ZeroBounce is skipped.
ZEROBOUNCE_API_KEY=

# =============================================================================
# Vercel (Production) — do this once per project
# =============================================================================
# 1. Project → Settings → Environment Variables — add ALL variables this file
#    lists for checkout, contact, email, and admin (same names, production values).
# 2. Required for /admin: SUPABASE_SERVICE_ROLE_KEY (exact name; not anon key),
#    ADMIN_PASSWORD (use a strong password; example above is fine if you rotate later).
# 3. Leave VITE_API_ORIGIN unset on Vercel unless the storefront is served from a
#    different origin than /api — otherwise admin calls the wrong host and env vars
#    from that deployment apply (often missing service role).
# 4. Supabase → SQL — run migrations as needed, e.g.:
#    store/supabase/migrations/005_order_completed.sql
#    store/supabase/migrations/006_drop_order_lines.sql (after deploy; removes legacy table)
# 5. Deploy from GitHub main; open https://YOUR_DOMAIN.vercel.app/admin
# =============================================================================
